GOOGLE_API_KEY="<you-api-key-here>"
OPENAI_API_KEY="<you-api-key-here>"
SILICONFLOW_API_KEY="<you-api-key-here>"

### Gradium — speech-to-text on the chat input mic button
###   url: https://gradium.ai → API keys
###   used by: src/endpoints/stt.py (POST /stt/transcribe)
GRADIUM_API_KEY="<you-api-key-here>"

## Database
### S3 (Bucket storage)
AWS_ACCESS_KEY_ID="<you-access-key-id-here>"
AWS_SECRET_ACCESS_KEY="<you-secret-access-key-here>"

### Postgres (Relational Database)
SUPABASE_URL="https://<project-ref>.supabase.co"
DATABASE_URL="postgresql://postgres:<your_password_here>@localhost:5432/postgres"
# Supabase Storage (chat file uploads)
#    Found in Supabase dashboard > Project Settings > API
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key-here>"
SUPABASE_STORAGE_BUCKET="chat-uploads"

### Redis (In-memory Database)
# Local: redis://:<password>@localhost:6379
# Upstash (TLS): rediss://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL="redis://:<your_redis_password>@localhost:6379"

# Upstash REST API (optional, used for serverless / HTTP transport)
# Found in Upstash console > Database > REST API
UPSTASH_REDIS_REST_URL="https://<endpoint>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<your_upstash_rest_token>"

### Qdrant (Vector Database)
# Local: http://localhost:6333
# Qdrant Cloud: https://<cluster-id>.<region>.cloud.qdrant.io:6333
QDRANT_URL="http://localhost:6333"
# Required for Qdrant Cloud, leave blank for unauthenticated local instances
QDRANT_API_KEY=""

## APIs
### url: https://www.n2yo.com/login/edit/
### content: fetch satellites data in real-time
N2YO_API_KEY="<you-api-key-here>"

### url: https://app.tavily.com/home
### content: search data on the web
TAVILY_API_KEY="<you-api-key-here>"

## ─────────── Ported from /preflight ─────────────────────────────────────
##  These power the multi-agent simulation, run lifecycle, Zep cross-run
##  memory, and Supabase JWT auth that ship as part of the merge.

### Zep Cloud — knowledge graph store, per-user graphs
###   url: https://getzep.com → Project → API Keys
ZEP_API_KEY=""

### Supabase auth — when the JWT secret is set, all /runs* /briefs*
###  /graph* /auth* /chat routes require an Authorization: Bearer <jwt>.
###  Empty = dev-local: every request is implicitly authenticated as
###  DEV_USER_ID (default "dev-local").
###   url: Supabase dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=""
DEV_USER_ID="dev-local"

### SiliconFlow base URL (default `.com` international, `.cn` for the
###  China-region console). The SILICONFLOW_API_KEY above is reused.
# SILICONFLOW_BASE_URL="https://api.siliconflow.com/v1"

### Per-task model bindings — overridable at runtime if needed.
ONTOLOGY_MODEL="Qwen/Qwen2.5-72B-Instruct"
PERSONA_MODEL="Qwen/Qwen2.5-72B-Instruct"
SIMULATION_MODEL="Qwen/Qwen3-8B"
REPORT_MODEL="deepseek-ai/DeepSeek-R1"
JUDGE_MODEL="deepseek-ai/DeepSeek-V3"
CHAT_MODEL="deepseek-ai/DeepSeek-V3"
EMBEDDING_MODEL="Qwen/Qwen3-Embedding-0.6B"

### Hard budget cap (USD) — the cost tracker aborts a run that crosses it.
BUDGET_USD=50

### CORS — comma-separated origin allowlist for browser clients. Required
###  for credentialed requests (cookies, Authorization header) to work
###  without browser blocking. Leaving this empty falls back to a
###  permissive wildcard *without* credentials, fine for curl / dev but
###  not for prod browser traffic.
###   Examples:
###     local dev:  http://localhost:3000
###     staging:    http://localhost:3000,https://staging.preflight.dev
###     prod:       https://app.preflight.dev
CORS_ALLOW_ORIGINS=""
